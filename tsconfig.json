{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.{ts,tsx,json}", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
